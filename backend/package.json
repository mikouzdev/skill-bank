{
  "name": "spankki-backend",
  "private": true,
  "version": "1.0.0",
  "description": "Backend for Spankki (name pending)",
  "main": "index.js",
  "scripts": {
    "env": "dotenvx run -f ../.env.example -f ../.env -f .env.example -f .env --overload",
    "dev": "pnpm run env -- tsx --watch ./src/index.ts",
    "test": "vitest",
    "lint": "eslint .",
    "db:generate": "pnpm run env -- prisma generate",
    "db:seed": "pnpm run env -- prisma db seed",
    "db:migrate": "pnpm run env -- prisma migrate dev",
    "generate:api-types": "openapi-typescript http://localhost:3000/openapi.json -o ../shared/generated/api-types/openapi.d.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.51.1",
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.5",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.1",
    "@types/swagger-ui-express": "^4.1.8",
    "cypress": "^15.10.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "openapi-types": "^12.1.3",
    "openapi-typescript": "^7.10.1",
    "prisma": "^7.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.1.0",
    "argon2": "^0.44.0",
    "express": "^5.1.0",
    "file-type": "^21.1.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.1.13",
    "zod-openapi": "^5.4.5"
  }
}
