// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  name         String
  email        String   @unique
  passwordHash String

  consultant  Consultant?
  salesperson Salesperson?
  customer    Customer?
  roles       UserRole[]
  comments    Comment[]
}

enum Visibility {
  LIMITED /// self, admins, salespeople, customers
  PUBLIC
}

model UserRole {
  id     Int  @id @default(autoincrement())
  userId Int
  role   Role

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
}

enum Role {
  CONSULTANT
  SALESPERSON
  CUSTOMER
  ADMIN
}

/// For social networking URLs, phone numbers, etc.
model ConsultantAttribute {
  id           Int               @id @default(autoincrement())
  consultantId Int
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  value        String
  label        String
  type         UserAttributeType @default(TEXT)
  visibility   Visibility        @default(PUBLIC)

  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)

  @@unique([consultantId, label])
}

enum UserAttributeType {
  TEXT
  LINK
}

model Consultant {
  id                Int    @id @default(autoincrement())
  userId            Int    @unique
  description       String
  roleTitle         String
  profilePictureUrl String

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesListItems       SalesListItem[]
  employments          Employment[]
  projects             Project[]
  consultantSkills     ConsultantSkill[]
  pageSections         PageSection[]
  consultantAttributes ConsultantAttribute[]
  consultantPages      ConsultantPages[]
}

model ConsultantSkill {
  id           Int      @id @default(autoincrement())
  consultantId Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  skillName    String
  /// Proficiency is rated on a scale 1-5
  proficiency  Int
  listPosition Int      @default(autoincrement())

  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  skillTag   SkillTag   @relation(fields: [skillName], references: [name], onDelete: Cascade)

  @@unique([consultantId, skillName])
}

model ProjectSkill {
  id           Int    @id @default(autoincrement())
  projectId    Int
  skillTagName String

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  skillTag SkillTag @relation(fields: [skillTagName], references: [name])

  @@unique([projectId, skillTagName])
}

model EmploymentSkill {
  id           Int    @id @default(autoincrement())
  employmentId Int
  skillTagName String

  employment Employment @relation(fields: [employmentId], references: [id], onDelete: Cascade)
  skillTag   SkillTag   @relation(fields: [skillTagName], references: [name])

  @@unique([employmentId, skillTagName])
}

/// Delete a SkillTag when the last reference is deleted
model SkillTag {
  id         Int    @id @default(autoincrement())
  categoryId Int?
  /// name should be stored in lowercase to prevent duplicates
  name       String @unique

  category         SkillCategory?    @relation(fields: [categoryId], references: [id])
  consultantSkills ConsultantSkill[]
  projectSkills    ProjectSkill[]
  employmentSkills EmploymentSkill[]
}

model SkillCategory {
  id   Int    @id @default(autoincrement())
  name String @unique

  skillTags SkillTag[]
}

model Employment {
  id           Int        @id @default(autoincrement())
  consultantId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  employer     String
  jobTitle     String
  description  String
  start        DateTime
  end          DateTime?
  visibility   Visibility @default(PUBLIC)

  consultant       Consultant        @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  employmentSkills EmploymentSkill[]
}

model Project {
  id           Int        @id @default(autoincrement())
  consultantId Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  name         String
  description  String
  start        DateTime
  end          DateTime?
  visibility   Visibility @default(PUBLIC)

  projectLinks  ProjectLink[]
  consultant    Consultant     @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  projectSkills ProjectSkill[]
}

model ProjectLink {
  id        Int      @id @default(autoincrement())
  projectId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  url       String
  label     String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Salesperson {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesLists SalesList[]
  offerPages OfferPages[]
}

/// Created by salespeople and viewable by customers.
model SalesList {
  id               Int     @id @default(autoincrement())
  salespersonId    Int
  customerId       Int?
  listPosition     Int     @default(autoincrement())
  description      String
  shortDescription String
  isReviewDone     Boolean @default(false) /// Customer's review

  salesperson    Salesperson     @relation(fields: [salespersonId], references: [id])
  customer       Customer?        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  salesListItems SalesListItem[]

  @@unique([salespersonId, listPosition])
}

/// Created by salespeople and viewable by customers.
/// An item cannot be at the same time accepted and hidden.
model SalesListItem {
  id           Int     @id @default(autoincrement())
  consultantId Int
  salesListId  Int
  listPosition Int     @default(autoincrement())
  isAccepted   Boolean @default(false)
  isHidden     Boolean @default(false)
  salesNote    String

  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  salesList  SalesList  @relation(fields: [salesListId], references: [id], onDelete: Cascade)

  @@unique([consultantId, salesListId])
  @@unique([salesListId, listPosition])
}

model Customer {
  id     Int @id @default(autoincrement())
  userId Int @unique

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  salesLists SalesList[]
  offerPages OfferPages[]
}

model PageSection {
  id           Int             @id @default(autoincrement())
  consultantId Int
  name         PageSectionName
  visibility   Visibility      @default(PUBLIC)

  consultant Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  comments   Comment[]

  @@unique([consultantId, name])
}

enum PageSectionName {
  GENERAL /// comments about the whole consultant page
  NETWORKING_LINKS
  DESCRIPTION
  SKILLS
  EMPLOYMENTS
  PROJECTS
}

model Comment {
  id            Int      @id @default(autoincrement())
  pageSectionId Int
  userId        Int /// user who creates the comment
  userRole      Role
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  listPosition  Int      @default(autoincrement())
  replyToId     Int?
  content       String

  pageSection   PageSection @relation(fields: [pageSectionId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  directReplyTo Comment?     @relation("reply", fields: [replyToId], references: [id])
  directReplies Comment[]   @relation("reply")

  @@unique([pageSectionId, listPosition])
}

model BlacklistedTokens {
  id    Int    @id @default(autoincrement())
  token String
}

/// Created by salespeople and viewable by customers.
model OfferPages {
  id               Int     @id @default(autoincrement())
  salespersonId    Int
  customerId       Int
  description      String?
  passwordHash     String
  name             String?
  shortDescription String?

  salesperson     Salesperson       @relation(fields: [salespersonId], references: [id], onDelete: Cascade)
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  consultantPages ConsultantPages[]
}

model ConsultantPages {
  id           Int        @id @default(autoincrement())
  offerPageId  Int
  consultantId Int
  showInfo     Boolean
  isAccepted   Boolean
  offerPage    OfferPages @relation(fields: [offerPageId], references: [id], onDelete: Cascade)
  Consultant   Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
}
